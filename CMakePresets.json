{
  "version": 6,
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Dev",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "clap",
      "displayName": "CLAP",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-clap",
      "cacheVariables": {
        "S3G_BUILD_CLAP_PLUGIN": "ON"
      }
    },
    {
      "name": "apps",
      "displayName": "Standalone Apps",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-apps",
      "cacheVariables": {
        "S3G_BUILD_STANDALONE_APPS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "clap",
      "configurePreset": "clap"
    },
    {
      "name": "apps",
      "configurePreset": "apps"
    }
  ]
}
